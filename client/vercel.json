{
  "rewrites": [
    { "source": "/join/:code", "destination": "/api/share/league/:code" },
    { "source": "/api/:path((?!og/|share/).*)", "destination": "https://iknowball.onrender.com/api/:path" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
